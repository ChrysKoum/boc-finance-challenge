# Local demo defaults can be left empty.
# For production, copy this file to .env and replace these values.

SITE_DOMAIN=my-domain.com
API_DOMAIN=api.my-domain.com
VITE_API_BASE_URL=https://api.my-domain.com
CORS_ORIGINS=https://my-domain.com

# Optional local overrides if ports 80/443 are already in use.
# Leave these unset on the Oracle VM.
# HTTP_PORT=8080
# HTTPS_PORT=8443
